# ATLAS frontend env — copy to .env.local for dev, or set these in the
# Cloudflare Pages → Settings → Environment variables dashboard for prod.

# Point at your deployed backend (Render / Fly / Railway / local)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase anon (read-only) — used for the browser's realtime subscriptions
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ-anon-key-here

# Optional — if set, the dashboard uses this key directly. If unset, paste the
# key into the Settings → Controls tab once and it is stored in localStorage.
NEXT_PUBLIC_DASHBOARD_API_KEY=

# Cloudflare Pages only: pin the Node version so the build uses the same
# runtime as your local dev.
NODE_VERSION=20
